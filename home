<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Haivi | Innovation Reimagined</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .gradient-text {
            background: linear-gradient(90deg, #3b82f6, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <nav class="flex justify-between items-center px-8 py-6 max-w-7xl mx-auto">
        <div class="text-2xl font-bold tracking-tighter">HAIVI</div>
        <div class="space-x-8 hidden md:flex font-medium text-sm">
            <a href="#about" class="hover:text-blue-600 transition">About</a>
            <a href="#projects" class="hover:text-blue-600 transition">Work</a>
            <a href="#contact" class="hover:text-blue-600 transition">Contact</a>
        </div>
    </nav>

    <header class="max-w-7xl mx-auto px-8 py-24 text-center">
        <h1 class="text-6xl md:text-8xl font-bold mb-6 tracking-tight">
            The future of <span class="gradient-text">digital experience.</span>
        </h1>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-10">
            Haivi merges clean aesthetics with robust performance to build tools that matter. 
        </p>
        <div class="flex justify-center gap-4">
            <a href="#projects" class="bg-slate-900 text-white px-8 py-3 rounded-full font-medium hover:bg-slate-800 transition">View Projects</a>
            <a href="#contact" class="border border-slate-300 px-8 py-3 rounded-full font-medium hover:bg-slate-100 transition">Get in Touch</a>
        </div>
    </header>

    <section id="projects" class="max-w-7xl mx-auto px-8 py-20">
        <h2 class="text-3xl font-bold mb-12">Featured Work</h2>
        <div class="grid md:grid-cols-2 gap-8">
            <div class="group cursor-pointer">
                <div class="aspect-video bg-slate-200 rounded-2xl mb-4 overflow-hidden">
                    <div class="w-full h-full bg-gradient-to-br from-blue-100 to-indigo-100 group-hover:scale-105 transition duration-500"></div>
                </div>
                <h3 class="text-xl font-semibold">Web Applications</h3>
                <p class="text-slate-500 text-sm">Dynamic, scalable solutions built with modern stacks.</p>
            </div>
            <div class="group cursor-pointer">
                <div class="aspect-video bg-slate-200 rounded-2xl mb-4 overflow-hidden">
                    <div class="w-full h-full bg-gradient-to-br from-purple-100 to-pink-100 group-hover:scale-105 transition duration-500"></div>
                </div>
                <h3 class="text-xl font-semibold">Creative Design</h3>
                <p class="text-slate-500 text-sm">Visual storytelling and brand identity optimization.</p>
            </div>
        </div>
    </section>

    <footer id="contact" class="bg-slate-900 text-white py-20 mt-20">
        <div class="max-w-7xl mx-auto px-8 text-center">
            <h2 class="text-4xl font-bold mb-6">Let's build something together.</h2>
            <p class="text-slate-400 mb-8">Reach out for collaborations or inquiries.</p>
            <a href="mailto:hello@haivi.com" class="text-2xl font-light hover:text-blue-400 transition underline underline-offset-8">hello@haivi.in</a>
            <div class="mt-12 text-xs text-slate-500 uppercase tracking-widest">
                &copy; 2026 Haivi. All Rights Reserved.
            </div>
        </div>
    </footer>

</body>
</html>
